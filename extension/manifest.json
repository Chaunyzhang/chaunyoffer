{
  "manifest_version": 3,
  "name": "Chauny后仰跳投",
  "version": "0.1.1",
  "description": "简历助手/投递简历：导入Word(docx)自动解析，结构化拆分项目/实习/教育，一键复制粘贴填写（京东等招聘表单）",
  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Chauny后仰跳投"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/jszip.min.js", "vendor/mammoth.browser.min.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
